# ============================================================================
# EXCEPTIONS (Files to KEEP even if pattern matches)
# ============================================================================

# Keep example environment file
!.env.example
!.env.sample

# Keep example config
!.streamlit/config.toml.example

# Keep README and docs
!README.md
!LICENSE
!*.md

# Keep requirements files
!requirements.txt
!requirements-dev.txt

# Keep specific database schema
!schema.sql
!migrations/

# Keep sample data
!sample_data/
!*.sample

# ============================================================================
# NOTES FOR CONTRIBUTORS
# ============================================================================
# 
# 1. NEVER commit .env files containing API keys
# 2. NEVER commit secrets.toml with production credentials
# 3. ALWAYS use .env.example as a template
# 4. User progress data should stay local (not in repo)
# 5. Cache files should not be version controlled
# 6. IDE configuration is personal - keep .gitignore
# 
# ============================================================================
