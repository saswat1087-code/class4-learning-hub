# ============================================================================
# CLASS 4 LEARNING HUB - ENVIRONMENT VARIABLES TEMPLATE
# Copy this file to .env and fill in your values
# NEVER commit .env file to version control!
# ============================================================================

# ============================================================================
# REQUIRED CONFIGURATION
# ============================================================================

# Google Gemini AI API Key
# Get your free API key from: https://makersuite.google.com/app/apikey
# This is REQUIRED for AI features to work
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================================================
# OPTIONAL CONFIGURATION
# ============================================================================

# Admin/Parent Zone Password
# Password to access the parent dashboard and detailed reports
# Default: class4teacher2026
ADMIN_PASSWORD=class4teacher2026

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================

# Application Environment
# Options: development, production, testing
# Default: development
APP_ENVIRONMENT=development

# Debug Mode
# Enables detailed error messages and debug output
# Options: true, false
# Default: false
DEBUG_MODE=false

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# Database Type
# Options: sqlite, postgresql, mysql
# Default: sqlite
DATABASE_TYPE=sqlite

# SQLite Database Path (only for sqlite)
# Default: learning_hub.db
SQLITE_DATABASE_PATH=learning_hub.db

# PostgreSQL Configuration (if using postgresql)
# DATABASE_URL=postgresql://username:password@localhost:5432/learning_hub

# MySQL Configuration (if using mysql)
# DATABASE_URL=mysql://username:password@localhost:3306/learning_hub

# ============================================================================
# EMAIL CONFIGURATION (for parent reports)
# ============================================================================

# SMTP Server Settings
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# SMTP_USE_TLS=true

# Email Sender
# SENDER_EMAIL=noreply@class4learninghub.com

# Email Recipients (comma-separated for multiple)
# PARENT_EMAILS=parent1@example.com,parent2@example.com

# ============================================================================
# AI MODEL CONFIGURATION
# ============================================================================

# Gemini Model Version
# Options: gemini-1.5-flash, gemini-1.5-pro, gemini-2.0-flash-exp
# Default: gemini-1.5-flash
GEMINI_MODEL=gemini-1.5-flash

# AI Response Temperature (creativity level)
# Range: 0.0 to 1.0 (higher = more creative)
# Default: 0.7
AI_TEMPERATURE=0.7

# Maximum Tokens per Response
# Default: 500
AI_MAX_TOKENS=500

# Enable AI Response Caching
# Options: true, false
# Default: true
AI_CACHE_ENABLED=true

# ============================================================================
# RATE LIMITING
# ============================================================================

# Maximum AI API calls per user per day
# Default: 100
MAX_AI_CALLS_PER_DAY=100

# Maximum quiz attempts per day
# Default: 30
MAX_QUIZ_ATTEMPTS_PER_DAY=30

# Maximum requests per minute
# Default: 60
MAX_REQUESTS_PER_MINUTE=60

# ============================================================================
# GAMIFICATION SETTINGS
# ============================================================================

# Points awarded for different activities
POINTS_PER_CORRECT_ANSWER=10
POINTS_PER_QUIZ_COMPLETION=20
POINTS_PER_CHAPTER_COMPLETION=50
POINTS_DAILY_LOGIN_BONUS=15
POINTS_WEEKLY_STREAK_BONUS=100

# Daily goal points for students
DAILY_GOAL_POINTS=50

# Session timeout (in minutes)
SESSION_TIMEOUT_MINUTES=30

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Enable/Disable features
ENABLE_VOICE_INPUT=false
ENABLE_VIDEO_LESSONS=false
ENABLE_PEER_TUTORING=false
ENABLE_CERTIFICATES=true
ENABLE_PROGRESS_SHARING=true
ENABLE_SOUND_EFFECTS=true
ENABLE_ANIMATIONS=true

# ============================================================================
# SECURITY SETTINGS
# ============================================================================

# CORS Allowed Origins (comma-separated)
# Default: http://localhost:8501,https://*.streamlit.app
CORS_ALLOWED_ORIGINS=http://localhost:8501,https://*.streamlit.app

# CSRF Protection
# Options: true, false
# Default: true
CSRF_PROTECTION_ENABLED=true

# Secure Cookie Flag (requires HTTPS)
# Options: true, false
# Default: false for local, true for production
SECURE_COOKIES=false

# ============================================================================
# MONITORING & ANALYTICS
# ============================================================================

# Enable anonymous usage statistics
# Options: true, false
# Default: false
ANONYMOUS_TELEMETRY=false

# Enable error tracking
# Options: true, false
# Default: true
ERROR_TRACKING_ENABLED=true

# Performance monitoring
# Options: true, false
# Default: false
PERFORMANCE_MONITORING=false

# ============================================================================
# BACKUP SETTINGS
# ============================================================================

# Enable automatic backups
# Options: true, false
# Default: true
AUTO_BACKUP_ENABLED=true

# Backup frequency (in hours)
# Default: 24
BACKUP_FREQUENCY_HOURS=24

# Number of backups to keep
# Default: 7
BACKUP_RETENTION_DAYS=7

# Backup directory path
# Default: backups
BACKUP_DIRECTORY=backups

# ============================================================================
# CACHE SETTINGS
# ============================================================================

# Maximum cache size (in MB)
# Default: 500
MAX_CACHE_SIZE_MB=500

# Cache TTL (time to live in seconds)
# Default: 3600 (1 hour)
CACHE_TTL_SECONDS=3600

# Enable browser caching
# Options: true, false
# Default: true
BROWSER_CACHING_ENABLED=true

# ============================================================================
# LOGGING
# ============================================================================

# Log level
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Default: INFO
LOG_LEVEL=INFO

# Log file path
# Default: logs/app.log
LOG_FILE_PATH=logs/app.log

# Maximum log file size (in MB)
# Default: 10
MAX_LOG_FILE_SIZE_MB=10

# Number of backup log files to keep
# Default: 5
LOG_BACKUP_COUNT=5

# ============================================================================
# DEVELOPMENT SETTINGS (only for local development)
# ============================================================================

# Auto-reload on file changes
# Options: true, false
# Default: false in production
AUTO_RELOAD=false

# Show tracebacks in UI
# Options: true, false
# Default: false in production
SHOW_TRACEBACKS=false

# Development mode (disables some optimizations)
# Options: true, false
# Default: false
DEVELOPMENT_MODE=false

# ============================================================================
# INTERNATIONALIZATION (i18n)
# ============================================================================

# Default language
# Options: en, es, fr, de, hi
# Default: en
DEFAULT_LANGUAGE=en

# Supported languages (comma-separated)
# Default: en,es
SUPPORTED_LANGUAGES=en,es

# ============================================================================
# THIRD-PARTY API KEYS (Optional)
# ============================================================================

# Google Custom Search API (for safe web search)
# GOOGLE_SEARCH_API_KEY=your_search_api_key
# GOOGLE_SEARCH_ENGINE_ID=your_search_engine_id

# Weather API (for science lessons)
# WEATHER_API_KEY=your_weather_api_key

# News API (for current events)
# NEWS_API_KEY=your_news_api_key

# ============================================================================
# EXAMPLE VALUES FOR DIFFERENT ENVIRONMENTS
# ============================================================================

# Development Environment (local)
# APP_ENVIRONMENT=development
# DEBUG_MODE=true
# AUTO_RELOAD=true
# SHOW_TRACEBACKS=true
# SECURE_COOKIES=false

# Production Environment (Streamlit Cloud)
# APP_ENVIRONMENT=production
# DEBUG_MODE=false
# AUTO_RELOAD=false
# SHOW_TRACEBACKS=false
# SECURE_COOKIES=true

# Testing Environment (CI/CD)
# APP_ENVIRONMENT=testing
# DEBUG_MODE=true
# AUTO_RELOAD=false
# SHOW_TRACEBACKS=true
# DATABASE_TYPE=sqlite
# SQLITE_DATABASE_PATH=test.db

# ============================================================================
# INSTRUCTIONS
# ============================================================================
# 
# 1. Copy this file to .env:
#    cp .env.example .env
# 
# 2. Edit .env and add your actual values:
#    - REQUIRED: GEMINI_API_KEY
#    - OPTIONAL: Modify other settings as needed
# 
# 3. NEVER commit .env to version control:
#    - .env is already in .gitignore
#    - Keep secrets out of GitHub
# 
# 4. For Streamlit Cloud deployment:
#    - Don't use .env file
#    - Add secrets in Streamlit Cloud dashboard
#    - Secret names should match these variable names
# 
# 5. For Docker deployment:
#    - Use --env-file flag:
#      docker run --env-file .env class4-learning-hub
# 
# ============================================================================
